#### 3.2.3 ck参数解密与URL构造

```javascript
function getFrameUrl() {
    var ck = getQueryString('ck');        // 从URL获取ck参数
    var decoded = atob(ck);              // Base64解码
    var decrypted = this.ultraDecrypt(decoded);  // 替换密码解密
    var parts = decrypted.split('/');
    var random = getRandomString(7);     // 7位随机字符串
    var scope = getCurrentScope();       // 当前时间戳
    
    // 构造最终URL: http://域名/随机串/路径/时间戳.html
    let url = 'http://' + parts[0] + '/' + random + '/' + parts[1];
    if (parts[2]) {
        url += '/' + scope + '/' + parts[2];
    } else {
        url += '/' + scope + '.html';
    }
    return url;
}

// 替换密码解密算法
function ultraDecrypt(encrypted) {
    const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-';
    const shift = parseInt(encrypted[0]);  // 第一个字符作为位移量
    let result = '';
    for (let i = 1; i < encrypted.length; i++) {
        const idx = alphabet.indexOf(encrypted[i]);
        if (idx !== -1) {
            let newIdx = idx - shift;
            if (newIdx < 0) newIdx += alphabet.length;
            result += alphabet[newIdx];
        } else {
            result += encrypted[i];
        }
    }
    return result;
}
```

